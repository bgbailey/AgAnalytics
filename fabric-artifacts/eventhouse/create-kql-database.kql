// =============================================================================
// AgriTech Analytics — Eventhouse KQL Database Creation Script
// =============================================================================
//
// Purpose:  Bootstrap the Fabric Eventhouse database for the AgriTech Analytics
//           greenhouse monitoring platform (BrightHarvest Greens + Mucci Valley
//           Farms). Creates tables, ingestion mappings, retention policies,
//           materialized views, and seeds reference data.
//
// Usage:    Paste each command block into the Fabric Eventhouse query editor
//           and execute sequentially. KQL management commands (.create, .alter,
//           .ingest) must be run one at a time — they cannot be batched.
//
// Tables:
//   SensorTelemetry   — Real-time sensor readings (30-sec interval, per zone)
//   EquipmentState    — Equipment actuator states (60-sec interval, per zone)
//   WeatherData       — External weather conditions (5-min interval, per greenhouse)
//   AlertEvents       — Anomaly / activator alert log
//   ZoneConfig        — Reference table: zone → crop setpoints (seeded inline)
//
// Materialized Views:
//   ZoneHourlySummary — Hourly aggregated sensor stats per zone
//   ZoneLatestReading — Latest sensor snapshot per zone (live dashboard)
//
// =============================================================================


// =============================================================================
// SECTION 1 — Core Telemetry Tables
// =============================================================================

// ---------------------------------------------------------------------------
// 1a. SensorTelemetry — primary real-time table
//     One row per zone per 30-second reading. 10 sensor channels plus
//     identifiers. This is the highest-volume table (~2.8M rows/day for
//     16 zones at 30-sec intervals).
// ---------------------------------------------------------------------------

.create-merge table SensorTelemetry (
    timestamp: datetime,
    greenhouse_id: string,
    zone_id: string,
    air_temperature: real,
    air_humidity: real,
    co2_level: real,
    par_light: real,
    substrate_temperature: real,
    substrate_moisture: real,
    substrate_ec: real,
    substrate_ph: real,
    water_flow_rate: real,
    vpd: real
)


// ---------------------------------------------------------------------------
// 1b. EquipmentState — actuator / equipment status per zone
//     One row per zone per 60-second interval. Tracks heating, cooling,
//     vents, lights, CO₂ injection, curtains, and irrigation.
// ---------------------------------------------------------------------------

.create-merge table EquipmentState (
    timestamp: datetime,
    greenhouse_id: string,
    zone_id: string,
    heating_output: real,
    cooling_output: real,
    vent_position: real,
    supplemental_light: bool,
    supplemental_light_watts: real,
    co2_injection_rate: real,
    thermal_curtain: real,
    irrigation_pump: bool,
    irrigation_flow: real,
    recirc_pump: bool
)


// ---------------------------------------------------------------------------
// 1c. WeatherData — external conditions per greenhouse location
//     One row per greenhouse per 5-minute interval. Used for correlating
//     indoor conditions with outdoor weather (energy optimization, anomaly
//     context).
// ---------------------------------------------------------------------------

.create-merge table WeatherData (
    timestamp: datetime,
    greenhouse_id: string,
    outside_temperature: real,
    outside_humidity: real,
    wind_speed: real,
    wind_direction: real,
    precipitation: real,
    solar_radiation: real,
    barometric_pressure: real,
    cloud_cover: real
)


// =============================================================================
// SECTION 2 — Alert Events Table
// =============================================================================

// ---------------------------------------------------------------------------
// Populated by anomaly detection logic and Data Activator rules.
// Captures severity, type, message, and anomaly score for post-incident
// analysis and the KQL graph blast-radius queries.
// ---------------------------------------------------------------------------

.create-merge table AlertEvents (
    timestamp: datetime,
    alert_id: string,
    greenhouse_id: string,
    zone_id: string,
    severity: string,
    alert_type: string,
    message: string,
    anomaly_score: real,
    acknowledged: bool
)


// =============================================================================
// SECTION 3 — Zone Configuration Reference Table
// =============================================================================

// ---------------------------------------------------------------------------
// Static reference data: maps each zone to its greenhouse, crop, target
// setpoints, and physical size. Seeded with inline data in Section 9.
// ---------------------------------------------------------------------------

.create-merge table ZoneConfig (
    zone_id: string,
    greenhouse_id: string,
    zone_name: string,
    crop_id: string,
    crop_name: string,
    target_temperature: real,
    target_humidity: real,
    target_co2: real,
    target_ph: real,
    target_ec: real,
    size_sqft: int
)


// =============================================================================
// SECTION 4 — Streaming Ingestion Policy
// =============================================================================

// Enable streaming ingestion on the high-frequency tables so that
// Eventstream data lands with sub-second latency (required for the
// live RTI dashboard demo).

.alter table SensorTelemetry policy streamingingestion enable

.alter table EquipmentState policy streamingingestion enable

.alter table WeatherData policy streamingingestion enable

.alter table AlertEvents policy streamingingestion enable


// =============================================================================
// SECTION 5 — JSON Ingestion Mappings (Event Hub → Eventhouse)
// =============================================================================

// ---------------------------------------------------------------------------
// 5a. SensorTelemetryMapping
//     Maps the JSON payload from the data-generator's SensorReading.to_dict()
//     output (sent via Event Hub) to the SensorTelemetry table columns.
// ---------------------------------------------------------------------------

.create-or-alter table SensorTelemetry ingestion json mapping 'SensorTelemetryMapping'
    '['
    '  {"column":"timestamp",             "path":"$.timestamp",             "datatype":"datetime"},'
    '  {"column":"greenhouse_id",         "path":"$.greenhouse_id",         "datatype":"string"},'
    '  {"column":"zone_id",               "path":"$.zone_id",               "datatype":"string"},'
    '  {"column":"air_temperature",       "path":"$.air_temperature",       "datatype":"real"},'
    '  {"column":"air_humidity",          "path":"$.air_humidity",          "datatype":"real"},'
    '  {"column":"co2_level",             "path":"$.co2_level",             "datatype":"real"},'
    '  {"column":"par_light",             "path":"$.par_light",             "datatype":"real"},'
    '  {"column":"substrate_temperature", "path":"$.substrate_temperature", "datatype":"real"},'
    '  {"column":"substrate_moisture",    "path":"$.substrate_moisture",    "datatype":"real"},'
    '  {"column":"substrate_ec",          "path":"$.substrate_ec",          "datatype":"real"},'
    '  {"column":"substrate_ph",          "path":"$.substrate_ph",          "datatype":"real"},'
    '  {"column":"water_flow_rate",       "path":"$.water_flow_rate",       "datatype":"real"},'
    '  {"column":"vpd",                   "path":"$.vpd",                   "datatype":"real"}'
    ']'


// ---------------------------------------------------------------------------
// 5b. EquipmentStateMapping
//     Maps EquipmentState.to_dict() JSON to the EquipmentState table.
// ---------------------------------------------------------------------------

.create-or-alter table EquipmentState ingestion json mapping 'EquipmentStateMapping'
    '['
    '  {"column":"timestamp",               "path":"$.timestamp",               "datatype":"datetime"},'
    '  {"column":"greenhouse_id",           "path":"$.greenhouse_id",           "datatype":"string"},'
    '  {"column":"zone_id",                 "path":"$.zone_id",                 "datatype":"string"},'
    '  {"column":"heating_output",          "path":"$.heating_output",          "datatype":"real"},'
    '  {"column":"cooling_output",          "path":"$.cooling_output",          "datatype":"real"},'
    '  {"column":"vent_position",           "path":"$.vent_position",           "datatype":"real"},'
    '  {"column":"supplemental_light",      "path":"$.supplemental_light",      "datatype":"bool"},'
    '  {"column":"supplemental_light_watts","path":"$.supplemental_light_watts","datatype":"real"},'
    '  {"column":"co2_injection_rate",      "path":"$.co2_injection_rate",      "datatype":"real"},'
    '  {"column":"thermal_curtain",         "path":"$.thermal_curtain",         "datatype":"real"},'
    '  {"column":"irrigation_pump",         "path":"$.irrigation_pump",         "datatype":"bool"},'
    '  {"column":"irrigation_flow",         "path":"$.irrigation_flow",         "datatype":"real"},'
    '  {"column":"recirc_pump",             "path":"$.recirc_pump",             "datatype":"bool"}'
    ']'


// ---------------------------------------------------------------------------
// 5c. WeatherDataMapping
//     Maps WeatherReading.to_dict() JSON to the WeatherData table.
// ---------------------------------------------------------------------------

.create-or-alter table WeatherData ingestion json mapping 'WeatherDataMapping'
    '['
    '  {"column":"timestamp",            "path":"$.timestamp",            "datatype":"datetime"},'
    '  {"column":"greenhouse_id",        "path":"$.greenhouse_id",        "datatype":"string"},'
    '  {"column":"outside_temperature",  "path":"$.outside_temperature",  "datatype":"real"},'
    '  {"column":"outside_humidity",     "path":"$.outside_humidity",     "datatype":"real"},'
    '  {"column":"wind_speed",           "path":"$.wind_speed",           "datatype":"real"},'
    '  {"column":"wind_direction",       "path":"$.wind_direction",       "datatype":"real"},'
    '  {"column":"precipitation",        "path":"$.precipitation",        "datatype":"real"},'
    '  {"column":"solar_radiation",      "path":"$.solar_radiation",      "datatype":"real"},'
    '  {"column":"barometric_pressure",  "path":"$.barometric_pressure",  "datatype":"real"},'
    '  {"column":"cloud_cover",          "path":"$.cloud_cover",          "datatype":"real"}'
    ']'


// ---------------------------------------------------------------------------
// 5d. AlertEventsMapping
//     Maps alert JSON (from Activator or notebook output) to AlertEvents.
// ---------------------------------------------------------------------------

.create-or-alter table AlertEvents ingestion json mapping 'AlertEventsMapping'
    '['
    '  {"column":"timestamp",      "path":"$.timestamp",      "datatype":"datetime"},'
    '  {"column":"alert_id",       "path":"$.alert_id",       "datatype":"string"},'
    '  {"column":"greenhouse_id",  "path":"$.greenhouse_id",  "datatype":"string"},'
    '  {"column":"zone_id",        "path":"$.zone_id",        "datatype":"string"},'
    '  {"column":"severity",       "path":"$.severity",       "datatype":"string"},'
    '  {"column":"alert_type",     "path":"$.alert_type",     "datatype":"string"},'
    '  {"column":"message",        "path":"$.message",        "datatype":"string"},'
    '  {"column":"anomaly_score",  "path":"$.anomaly_score",  "datatype":"real"},'
    '  {"column":"acknowledged",   "path":"$.acknowledged",   "datatype":"bool"}'
    ']'


// =============================================================================
// SECTION 6 — Retention & Caching Policies
// =============================================================================

// ---------------------------------------------------------------------------
// High-frequency telemetry tables: 90 days hot cache, 2-year soft delete.
// The hot cache keeps 3 months of data on SSD for fast dashboard queries;
// older data remains queryable from cold storage for trend analysis.
// ---------------------------------------------------------------------------

// --- SensorTelemetry ---
.alter table SensorTelemetry policy retention softdelete = 730d

.alter table SensorTelemetry policy caching hot = 90d

// --- EquipmentState ---
.alter table EquipmentState policy retention softdelete = 730d

.alter table EquipmentState policy caching hot = 90d

// --- WeatherData ---
.alter table WeatherData policy retention softdelete = 730d

.alter table WeatherData policy caching hot = 90d

// ---------------------------------------------------------------------------
// AlertEvents: 365 days hot cache (alerts are low-volume, high-value;
// keep the full year in hot cache for incident investigations).
// ---------------------------------------------------------------------------

.alter table AlertEvents policy retention softdelete = 730d

.alter table AlertEvents policy caching hot = 365d

// ---------------------------------------------------------------------------
// ZoneConfig: static reference — no retention policy needed (tiny table).
// ---------------------------------------------------------------------------


// =============================================================================
// SECTION 7 — Partitioning Policy (optional performance optimization)
// =============================================================================

// Partition SensorTelemetry by greenhouse_id for query-time pruning.
// Most dashboard queries filter to one greenhouse; this cuts scan volume in half.

.alter table SensorTelemetry policy partitioning
```
{
  "PartitionKeys": [
    {
      "ColumnName": "greenhouse_id",
      "Kind": "Hash",
      "Properties": {
        "Function": "XxHash64",
        "MaxPartitionCount": 16,
        "PartitionAssignmentMode": "Uniform"
      }
    }
  ]
}
```


// =============================================================================
// SECTION 8 — Materialized Views
// =============================================================================

// ---------------------------------------------------------------------------
// 8a. ZoneHourlySummary
//     Pre-aggregated hourly statistics per zone. Powers time-series charts on
//     the executive dashboard without scanning the full SensorTelemetry table.
//     Columns: avg/min/max temp, avg humidity, avg CO₂, avg PAR, avg VPD,
//     avg EC, avg pH, reading count.
// ---------------------------------------------------------------------------

.create materialized-view with (backfill = true) ZoneHourlySummary on table SensorTelemetry {
    SensorTelemetry
    | summarize
        avg_temp = avg(air_temperature),
        min_temp = min(air_temperature),
        max_temp = max(air_temperature),
        avg_humidity = avg(air_humidity),
        avg_co2 = avg(co2_level),
        avg_par = avg(par_light),
        avg_vpd = avg(vpd),
        avg_substrate_temp = avg(substrate_temperature),
        avg_substrate_moisture = avg(substrate_moisture),
        avg_ec = avg(substrate_ec),
        avg_ph = avg(substrate_ph),
        avg_water_flow = avg(water_flow_rate),
        reading_count = count()
    by zone_id, greenhouse_id, bin(timestamp, 1h)
}


// ---------------------------------------------------------------------------
// 8b. ZoneLatestReading
//     Returns the single most recent sensor reading per zone. This is the
//     workhorse behind the "Current Zone Status" tiles on the RTI dashboard.
//     Uses arg_max to grab the full row for the latest timestamp per zone.
// ---------------------------------------------------------------------------

.create materialized-view with (backfill = true) ZoneLatestReading on table SensorTelemetry {
    SensorTelemetry
    | summarize arg_max(timestamp, *) by zone_id
}


// ---------------------------------------------------------------------------
// 8c. EquipmentLatestState
//     Most recent equipment state per zone — powers the equipment status panel.
// ---------------------------------------------------------------------------

.create materialized-view with (backfill = true) EquipmentLatestState on table EquipmentState {
    EquipmentState
    | summarize arg_max(timestamp, *) by zone_id
}


// ---------------------------------------------------------------------------
// 8d. DailyAlertSummary
//     Daily alert counts by greenhouse, severity, and type — for the anomaly
//     trend chart on the operations dashboard.
// ---------------------------------------------------------------------------

.create materialized-view with (backfill = true) DailyAlertSummary on table AlertEvents {
    AlertEvents
    | summarize
        alert_count = count(),
        avg_anomaly_score = avg(anomaly_score),
        acknowledged_count = countif(acknowledged)
    by greenhouse_id, severity, alert_type, bin(timestamp, 1d)
}


// =============================================================================
// SECTION 9 — Seed ZoneConfig Reference Data
// =============================================================================

// ---------------------------------------------------------------------------
// Inline ingest of all 16 grow zones with their crop setpoints.
// Derived from config.py: zone → crop mapping, crop optimal setpoints,
// and zone physical size.
//
// Columns: zone_id, greenhouse_id, zone_name, crop_id, crop_name,
//          target_temperature, target_humidity, target_co2, target_ph,
//          target_ec, size_sqft
// ---------------------------------------------------------------------------

.ingest inline into table ZoneConfig <|
BH-Z01,brightharvest,Zone 1,baby_spinach,Baby Spinach,18.0,70.0,800,6.0,1.8,25000
BH-Z02,brightharvest,Zone 2,baby_spinach,Baby Spinach,18.0,70.0,800,6.0,1.8,25000
