// =============================================================================
// SECTION 10 — Utility Functions
// =============================================================================

// ---------------------------------------------------------------------------
// 10a. Sensor deviation function
//      Returns how far each sensor channel is from the zone's crop setpoint.
//      Useful for anomaly scoring and dashboard deviation indicators.
// ---------------------------------------------------------------------------

.create-or-alter function with (docstring = "Calculate sensor deviation from crop setpoints for a given zone", folder = "AgriTech") 
ZoneSensorDeviation(target_zone_id: string, lookback: timespan = 1h) {
    let config = ZoneConfig | where zone_id == target_zone_id;
    let target_temp = toscalar(config | project target_temperature);
    let target_hum = toscalar(config | project target_humidity);
    let target_co2 = toscalar(config | project target_co2);
    let target_ph = toscalar(config | project target_ph);
    let target_ec = toscalar(config | project target_ec);
    SensorTelemetry
    | where zone_id == target_zone_id
    | where timestamp > ago(lookback)
    | extend
        temp_deviation = air_temperature - target_temp,
        humidity_deviation = air_humidity - target_hum,
        co2_deviation = co2_level - target_co2,
        ph_deviation = substrate_ph - target_ph,
        ec_deviation = substrate_ec - target_ec
    | project
        timestamp, zone_id, greenhouse_id,
        air_temperature, temp_deviation,
        air_humidity, humidity_deviation,
        co2_level, co2_deviation,
        substrate_ph, ph_deviation,
        substrate_ec, ec_deviation,
        par_light, vpd, water_flow_rate,
        substrate_temperature, substrate_moisture
}


// ---------------------------------------------------------------------------
// 10b. Anomaly detection function
//      Uses series_decompose_anomalies to detect outliers in the sensor
//      time-series for a given zone and metric. Returns anomaly flags and
//      scores for the requested lookback period.
// ---------------------------------------------------------------------------

.create-or-alter function with (docstring = "Detect anomalies in a sensor metric for a zone using series_decompose_anomalies", folder = "AgriTech") 
DetectSensorAnomalies(target_zone_id: string, lookback: timespan = 6h, bin_size: timespan = 5m) {
    SensorTelemetry
    | where zone_id == target_zone_id
    | where timestamp > ago(lookback)
    | summarize
        avg_temp = avg(air_temperature),
        avg_humidity = avg(air_humidity),
        avg_co2 = avg(co2_level),
        avg_vpd = avg(vpd),
        avg_ph = avg(substrate_ph),
        avg_ec = avg(substrate_ec),
        avg_moisture = avg(substrate_moisture)
    by bin(timestamp, bin_size)
    | order by timestamp asc
    | summarize
        ts = make_list(timestamp),
        temp_series = make_list(avg_temp),
        humidity_series = make_list(avg_humidity),
        co2_series = make_list(avg_co2),
        vpd_series = make_list(avg_vpd)
    | extend temp_anomalies = series_decompose_anomalies(temp_series)
    | extend humidity_anomalies = series_decompose_anomalies(humidity_series)
    | extend co2_anomalies = series_decompose_anomalies(co2_series)
    | mv-expand
        ts to typeof(datetime),
        temp_series to typeof(real),
        humidity_series to typeof(real),
        co2_series to typeof(real),
        vpd_series to typeof(real),
        temp_anomalies to typeof(real),
        humidity_anomalies to typeof(real),
        co2_anomalies to typeof(real)
    | project
        timestamp = ts,
        zone_id = target_zone_id,
        avg_temp = temp_series,
        temp_anomaly_flag = temp_anomalies,
        avg_humidity = humidity_series,
        humidity_anomaly_flag = humidity_anomalies,
        avg_co2 = co2_series,
        co2_anomaly_flag = co2_anomalies,
        avg_vpd = vpd_series
    | where temp_anomaly_flag != 0 or humidity_anomaly_flag != 0 or co2_anomaly_flag != 0
}


// ---------------------------------------------------------------------------
// 10c. Zone status summary function
//      Returns a single-row status for each zone: latest readings, deviation
//      from setpoints, and a simple health score (0–100).
// ---------------------------------------------------------------------------

.create-or-alter function with (docstring = "Dashboard-ready zone status with health score", folder = "AgriTech")
ZoneStatusDashboard() {
    ZoneLatestReading
    | join kind=inner ZoneConfig on zone_id
    | extend
        temp_deviation = abs(air_temperature - target_temperature),
        humidity_deviation = abs(air_humidity - target_humidity),
        co2_deviation = abs(co2_level - target_co2),
        ph_deviation = abs(substrate_ph - target_ph),
        ec_deviation = abs(substrate_ec - target_ec)
    | extend
        // Health score: start at 100, penalize proportionally for deviations
        health_score = max_of(0.0,
            100.0
            - (temp_deviation * 5.0)        // 1°C off = -5 points
            - (humidity_deviation * 1.0)     // 1% off = -1 point
            - (co2_deviation * 0.02)         // 50 ppm off = -1 point
            - (ph_deviation * 20.0)          // 0.1 pH off = -2 points
            - (ec_deviation * 10.0)          // 0.1 mS/cm off = -1 point
        )
    | project
        zone_id,
        greenhouse_id = ZoneLatestReading.greenhouse_id,
        crop_name,
        zone_name,
        timestamp,
        air_temperature, target_temperature, temp_deviation,
        air_humidity, target_humidity, humidity_deviation,
        co2_level, target_co2, co2_deviation,
        substrate_ph, target_ph, ph_deviation,
        substrate_ec, target_ec, ec_deviation,
        par_light, vpd, water_flow_rate,
        substrate_temperature, substrate_moisture,
        health_score
    | order by greenhouse_id asc, zone_id asc
}


// =============================================================================
// SECTION 11 — Update Policies (optional — for derived enrichment)
// =============================================================================

// Placeholder: If you need to automatically enrich incoming telemetry
// (e.g., join with ZoneConfig to add crop_name on ingest), define an
// update policy here. Example:
//
// .create-or-alter function SensorTelemetryEnriched() {
//     SensorTelemetry
//     | join kind=inner ZoneConfig on zone_id
//     | project-away zone_id1, greenhouse_id1
// }
//
// .alter table EnrichedTelemetry policy update
//     @'[{"Source":"SensorTelemetry","Query":"SensorTelemetryEnriched()",
//         "IsEnabled":true,"IsTransactional":true}]'


// =============================================================================
// VERIFICATION QUERIES — Run after setup to confirm everything is in place
// =============================================================================

// Check all tables were created:
// .show tables

// Check ingestion mappings:
// .show table SensorTelemetry ingestion json mappings
// .show table EquipmentState ingestion json mappings
// .show table WeatherData ingestion json mappings
// .show table AlertEvents ingestion json mappings

// Verify ZoneConfig seed data (should return 16 rows):
// ZoneConfig | count
// ZoneConfig | order by zone_id asc

// Check materialized views:
// .show materialized-views

// Check retention policies:
// .show table SensorTelemetry policy retention
// .show table SensorTelemetry policy caching

// Check stored functions:
// .show functions
