BH-Z04,brightharvest,Zone 4,romaine,Romaine Lettuce,20.0,65.0,900,6.2,2.0,25000
BH-Z05,brightharvest,Zone 5,arugula,Arugula,19.0,68.0,850,6.0,1.6,25000
BH-Z06,brightharvest,Zone 6,arugula,Arugula,19.0,68.0,850,6.0,1.6,25000
BH-Z07,brightharvest,Zone 7,basil,Basil,24.0,60.0,1000,5.8,1.4,25000
BH-Z08,brightharvest,Zone 8,basil,Basil,24.0,60.0,1000,5.8,1.4,25000
MV-Z01,mucci-valley,Zone 1,cocktail_tomato,Cocktail Tomato,23.0,70.0,1000,5.8,2.8,31250
MV-Z02,mucci-valley,Zone 2,cocktail_tomato,Cocktail Tomato,23.0,70.0,1000,5.8,2.8,31250
MV-Z03,mucci-valley,Zone 3,bell_pepper,Bell Pepper,22.0,65.0,900,6.0,2.5,31250
MV-Z04,mucci-valley,Zone 4,bell_pepper,Bell Pepper,22.0,65.0,900,6.0,2.5,31250
MV-Z05,mucci-valley,Zone 5,mini_cucumber,Mini Cucumber,24.0,75.0,900,5.8,2.2,31250
MV-Z06,mucci-valley,Zone 6,mini_cucumber,Mini Cucumber,24.0,75.0,900,5.8,2.2,31250
MV-Z07,mucci-valley,Zone 7,strawberry,Strawberry,20.0,65.0,800,5.8,1.4,31250
