// =============================================================================
// GREENHOUSE DIGITAL TWIN — KQL Graph Model & Seed Data
// =============================================================================
//
// AgriTech Analytics — KQL Graph Semantics for equipment dependency,
// blast-radius analysis, and runbook automation.
//
// This script creates:
//   1. Node tables (Greenhouse, Zone, Sensor, Crop, Equipment, RunbookAction, AnomalyType)
//   2. Edge tables (contains, grows, has_sensor, controlled_by, adjacent_to,
//      depends_on, resolves_with, triggers)
//   3. Graph model definition (GreenhouseDigitalTwin)
//   4. Seed data for both greenhouses (BrightHarvest + Mucci Valley)
//   5. Demo graph queries (blast radius, runbook lookup, dependency chain)
//
// Execute each .create / .ingest block one at a time in Fabric Eventhouse.
// =============================================================================


// =============================================================================
// SECTION 1 — NODE TABLES
// =============================================================================

// --- 1a. Greenhouse nodes ---
.create-merge table GraphNode_Greenhouse (
    node_id: string,
    name: string,
    location: string,
    country: string,
    zone_count: int,
    size_sqft: int
)

// --- 1b. Zone nodes ---
.create-merge table GraphNode_Zone (
    node_id: string,
    zone_id: string,
    greenhouse_id: string,
    zone_name: string,
    crop_id: string,
    crop_name: string,
    size_sqft: int,
    target_temperature: real,
    target_humidity: real,
    target_co2: real,
    target_ph: real,
    target_ec: real
)

// --- 1c. Sensor nodes ---
.create-merge table GraphNode_Sensor (
    node_id: string,
    sensor_id: string,
    zone_id: string,
    sensor_type: string,
    unit: string
)

// --- 1d. Crop nodes ---
.create-merge table GraphNode_Crop (
    node_id: string,
    crop_id: string,
    crop_name: string,
    category: string,
    optimal_temp_low: real,
    optimal_temp_high: real,
    days_to_harvest: int
)

// --- 1e. Equipment nodes ---
.create-merge table GraphNode_Equipment (
    node_id: string,
    equipment_id: string,
    zone_id: string,
    equipment_type: string,
    equipment_name: string,
    is_critical: bool
)

// --- 1f. RunbookAction nodes ---
.create-merge table GraphNode_RunbookAction (
    node_id: string,
    action_id: string,
    anomaly_type: string,
    step_order: int,
    action_name: string,
    description: string,
    automated: bool,
    sla_minutes: int
)

// --- 1g. AnomalyType nodes ---
.create-merge table GraphNode_AnomalyType (
    node_id: string,
    anomaly_type: string,
    display_name: string,
    severity: string,
    description: string
)


// =============================================================================
// SECTION 2 — EDGE TABLES
// =============================================================================

// --- 2a. contains: Greenhouse → Zone ---
.create-merge table GraphEdge_Contains (
    source_id: string,
    target_id: string,
    relationship: string
)

// --- 2b. grows: Zone → Crop ---
.create-merge table GraphEdge_Grows (
    source_id: string,
    target_id: string,
    relationship: string
)

// --- 2c. has_sensor: Zone → Sensor ---
.create-merge table GraphEdge_HasSensor (
    source_id: string,
    target_id: string,
    relationship: string
)

// --- 2d. controlled_by: Zone → Equipment ---
.create-merge table GraphEdge_ControlledBy (
    source_id: string,
    target_id: string,
    relationship: string
)

// --- 2e. adjacent_to: Zone ↔ Zone ---
.create-merge table GraphEdge_AdjacentTo (
    source_id: string,
    target_id: string,
    relationship: string
)

// --- 2f. depends_on: Equipment → Equipment ---
.create-merge table GraphEdge_DependsOn (
    source_id: string,
    target_id: string,
    relationship: string,
    dependency_type: string
)

// --- 2g. resolves_with: AnomalyType → RunbookAction ---
.create-merge table GraphEdge_ResolvesWith (
    source_id: string,
    target_id: string,
    relationship: string
)

// --- 2h. triggers: AnomalyType → Zone (which anomaly types affect which zones) ---
.create-merge table GraphEdge_Triggers (
    source_id: string,
    target_id: string,
    relationship: string
)


// =============================================================================
// SECTION 3 — SEED NODE DATA
// =============================================================================

