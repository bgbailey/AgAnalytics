// =============================================================================
// SECTION 5 — GRAPH MODEL DEFINITION
// =============================================================================
// Creates the GreenhouseDigitalTwin graph model with typed nodes and edges.
// This enables graph-match queries for blast-radius, dependency chain,
// and runbook automation.

.create-or-alter graph_model GreenhouseDigitalTwin ```
{
  "Schema": {
    "Nodes": [
      {
        "Label": "Greenhouse",
        "Table": "GraphNode_Greenhouse",
        "IdColumn": "node_id",
        "Properties": ["name", "location", "country", "zone_count", "size_sqft"]
      },
      {
        "Label": "Zone",
        "Table": "GraphNode_Zone",
        "IdColumn": "node_id",
        "Properties": ["zone_id", "greenhouse_id", "zone_name", "crop_id", "crop_name", "size_sqft", "target_temperature", "target_humidity", "target_co2", "target_ph", "target_ec"]
      },
      {
        "Label": "Sensor",
        "Table": "GraphNode_Sensor",
        "IdColumn": "node_id",
        "Properties": ["sensor_id", "zone_id", "sensor_type", "unit"]
      },
      {
        "Label": "Crop",
        "Table": "GraphNode_Crop",
        "IdColumn": "node_id",
        "Properties": ["crop_id", "crop_name", "category", "optimal_temp_low", "optimal_temp_high", "days_to_harvest"]
      },
      {
        "Label": "Equipment",
        "Table": "GraphNode_Equipment",
        "IdColumn": "node_id",
        "Properties": ["equipment_id", "zone_id", "equipment_type", "equipment_name", "is_critical"]
      },
      {
        "Label": "RunbookAction",
        "Table": "GraphNode_RunbookAction",
        "IdColumn": "node_id",
        "Properties": ["action_id", "anomaly_type", "step_order", "action_name", "description", "automated", "sla_minutes"]
      },
      {
        "Label": "AnomalyType",
        "Table": "GraphNode_AnomalyType",
        "IdColumn": "node_id",
        "Properties": ["anomaly_type", "display_name", "severity", "description"]
      }
    ],
    "Edges": [
      {
        "Label": "contains",
        "Table": "GraphEdge_Contains",
        "SourceColumn": "source_id",
        "TargetColumn": "target_id",
        "Properties": ["relationship"]
      },
      {
        "Label": "grows",
        "Table": "GraphEdge_Grows",
        "SourceColumn": "source_id",
        "TargetColumn": "target_id",
        "Properties": ["relationship"]
      },
      {
        "Label": "has_sensor",
        "Table": "GraphEdge_HasSensor",
        "SourceColumn": "source_id",
        "TargetColumn": "target_id",
        "Properties": ["relationship"]
      },
      {
        "Label": "controlled_by",
        "Table": "GraphEdge_ControlledBy",
        "SourceColumn": "source_id",
        "TargetColumn": "target_id",
        "Properties": ["relationship"]
      },
      {
        "Label": "adjacent_to",
        "Table": "GraphEdge_AdjacentTo",
        "SourceColumn": "source_id",
        "TargetColumn": "target_id",
        "Properties": ["relationship"]
      },
      {
        "Label": "depends_on",
        "Table": "GraphEdge_DependsOn",
        "SourceColumn": "source_id",
        "TargetColumn": "target_id",
        "Properties": ["relationship", "dependency_type"]
      },
      {
        "Label": "resolves_with",
        "Table": "GraphEdge_ResolvesWith",
        "SourceColumn": "source_id",
        "TargetColumn": "target_id",
        "Properties": ["relationship"]
      },
      {
        "Label": "triggers",
        "Table": "GraphEdge_Triggers",
        "SourceColumn": "source_id",
        "TargetColumn": "target_id",
        "Properties": ["relationship"]
      }
    ]
  }
}
```


// =============================================================================
// SECTION 6 — DEMO GRAPH QUERIES
// =============================================================================

// ---------------------------------------------------------------------------
// 6a. BLAST RADIUS QUERY
//     "What's affected if Zone BH-Z05 goes down?"
//     Traverses: Zone → adjacent zones, Zone → equipment, Zone → sensors,
//     Zone → crop to show the full impact of a zone failure.
// ---------------------------------------------------------------------------

let all_nodes = union
    (GraphNode_Greenhouse | project node_id, label = "Greenhouse", name = name),
    (GraphNode_Zone | project node_id, label = "Zone", name = zone_name),
    (GraphNode_Sensor | project node_id, label = "Sensor", name = sensor_type),
    (GraphNode_Crop | project node_id, label = "Crop", name = crop_name),
    (GraphNode_Equipment | project node_id, label = "Equipment", name = equipment_name);
let all_edges = union
    (GraphEdge_Contains | project source_id, target_id, edge_label = relationship),
    (GraphEdge_Grows | project source_id, target_id, edge_label = relationship),
    (GraphEdge_AdjacentTo | project source_id, target_id, edge_label = relationship),
    (GraphEdge_DependsOn | project source_id, target_id, edge_label = relationship);
all_nodes
| make-graph source_id --> target_id on node_id with all_edges
| graph-match (source)-[e*1..2]->(target)
    where source.node_id == "zone:BH-Z05"
    project 
        source_name = source.name,
        target_id = target.node_id,
        target_name = target.name,
        target_label = target.label


// ---------------------------------------------------------------------------
// 6b. RUNBOOK LOOKUP QUERY
//     "What are the steps for an hvac-failure?"
//     Traverses: AnomalyType → RunbookAction to return ordered steps.
// ---------------------------------------------------------------------------

let anomaly_nodes = GraphNode_AnomalyType
    | project node_id, label = "AnomalyType", name = display_name, anomaly_type;
let runbook_nodes = GraphNode_RunbookAction
    | project node_id, label = "RunbookAction", name = action_name, 
        anomaly_type, step_order, description, automated, sla_minutes;
let resolve_edges = GraphEdge_ResolvesWith
    | project source_id, target_id, edge_label = relationship;
union anomaly_nodes, (runbook_nodes | project node_id, label, name)
| make-graph source_id --> target_id on node_id with resolve_edges
| graph-match (anomaly)-[resolves]->(action)
    where anomaly.node_id == "anomaly:hvac-failure"
    project 
        anomaly_name = anomaly.name,
        step = action.node_id
| join kind=inner (GraphNode_RunbookAction) on $left.step == $right.node_id
| project step_order, action_name, description, automated, sla_minutes
| order by step_order asc


// ---------------------------------------------------------------------------
// 6c. EQUIPMENT DEPENDENCY CHAIN
//     "What depends on the recirculation pump in BH-Z05?"
//     Follows depends_on edges to show cascading equipment failures.
// ---------------------------------------------------------------------------

let equip_nodes = GraphNode_Equipment
    | project node_id, label = "Equipment", name = equipment_name, 
        equipment_type, zone_id, is_critical;
let dep_edges = GraphEdge_DependsOn
    | project source_id, target_id, edge_label = relationship, dependency_type;
equip_nodes
| make-graph source_id --> target_id on node_id with dep_edges
| graph-match (dependent)-[dep]->(dependency)
    where dependency.node_id == "equip:BH-Z05-recpump"
    project
        dependency_name = dependency.name,
        dependency_zone = dependency.zone_id,
        dependent_name = dependent.name,
        dependent_zone = dependent.zone_id,
        is_critical = dependent.is_critical


// ---------------------------------------------------------------------------
// 6d. FULL GREENHOUSE TOPOLOGY
//     "Show me everything in BrightHarvest Greens"
//     Traverses: Greenhouse → Zone → (Equipment, Sensor, Crop)
// ---------------------------------------------------------------------------

let all_nodes = union
    (GraphNode_Greenhouse | project node_id, label = "Greenhouse", name = name),
    (GraphNode_Zone | project node_id, label = "Zone", name = zone_name),
    (GraphNode_Equipment | project node_id, label = "Equipment", name = equipment_name),
    (GraphNode_Crop | project node_id, label = "Crop", name = crop_name);
let all_edges = union
    (GraphEdge_Contains | project source_id, target_id, edge_label = relationship),
    (GraphEdge_Grows | project source_id, target_id, edge_label = relationship);
all_nodes
| make-graph source_id --> target_id on node_id with all_edges
| graph-match (gh)-[e1]->(zone)-[e2]->(child)
    where gh.node_id == "greenhouse:brightharvest"
    project 
        greenhouse = gh.name,
        zone = zone.name,
        child_type = child.label,
        child_name = child.name
| order by zone asc, child_type asc
