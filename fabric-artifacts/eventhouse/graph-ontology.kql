// --- 3f. AnomalyType nodes (4 demo scenarios) ---
.ingest inline into table GraphNode_AnomalyType <|
anomaly:hvac-failure,hvac-failure,HVAC Failure,critical,Boiler or heating pipe offline causing temperature drop below crop setpoint
anomaly:nutrient-drift,nutrient-drift,Nutrient Drift,warning,pH and/or EC drifting outside optimal range indicating dosing pump malfunction
anomaly:irrigation-failure,irrigation-failure,Irrigation Failure,critical,Irrigation pump failure causing substrate moisture to drop rapidly
anomaly:cold-chain-break,cold-chain-break,Cold Chain Break,critical,Post-harvest refrigeration failure causing product temperature to exceed 5°C

// --- 3g. RunbookAction nodes (prioritized steps per anomaly type) ---
.ingest inline into table GraphNode_RunbookAction <|
runbook:hvac-1,hvac-1,hvac-failure,1,Verify Boiler Status,Check boiler control panel for error codes and fuel supply status,false,5
runbook:hvac-2,hvac-2,hvac-failure,2,Check Heat Pipe Circulation,Verify hot water circulation pump is running and pipes are warm,false,10
runbook:hvac-3,hvac-3,hvac-failure,3,Activate Backup Heater,Switch to backup propane heater if boiler cannot be restarted,false,15
runbook:hvac-4,hvac-4,hvac-failure,4,Close Vents and Curtains,Close all roof vents and deploy thermal curtains to retain heat,true,2
runbook:hvac-5,hvac-5,hvac-failure,5,Notify Maintenance Team,Send Teams alert to on-call maintenance engineer with zone details,true,1
runbook:hvac-6,hvac-6,hvac-failure,6,Log Incident,Create incident ticket with timestamp and affected zone details,true,1
runbook:nutrient-1,nutrient-1,nutrient-drift,1,Check Dosing Pump,Inspect nutrient dosing pump for blockages or calibration drift,false,10
runbook:nutrient-2,nutrient-2,nutrient-drift,2,Test Solution Sample,Take manual sample of nutrient solution and test pH/EC with handheld meter,false,15
runbook:nutrient-3,nutrient-3,nutrient-drift,3,Flush Irrigation Lines,Run clean water flush cycle through affected zone irrigation lines,false,20
runbook:nutrient-4,nutrient-4,nutrient-drift,4,Recalibrate Sensors,Recalibrate pH and EC sensors with buffer solutions,false,30
runbook:nutrient-5,nutrient-5,nutrient-drift,5,Notify Grower,Alert head grower via Teams with pH/EC readings and deviation trend,true,1
runbook:irrigation-1,irrigation-1,irrigation-failure,1,Check Pump Power,Verify irrigation pump has power and circuit breaker is not tripped,false,5
runbook:irrigation-2,irrigation-2,irrigation-failure,2,Inspect Pump Intake,Check pump intake filter for debris or clogging,false,10
runbook:irrigation-3,irrigation-3,irrigation-failure,3,Verify Flow Sensors,Cross-check flow meter readings with visual pipe inspection,false,10
runbook:irrigation-4,irrigation-4,irrigation-failure,4,Activate Manual Watering,Switch to manual overhead watering for affected zones,false,15
runbook:irrigation-5,irrigation-5,irrigation-failure,5,Notify Operations,Send Teams alert to operations team with moisture trend data,true,1
runbook:coldchain-1,coldchain-1,cold-chain-break,1,Check Reefer Unit,Verify refrigeration unit on transport vehicle is running,false,5
runbook:coldchain-2,coldchain-2,cold-chain-break,2,Check Door Seals,Inspect trailer door seals for gaps or damage,false,10
runbook:coldchain-3,coldchain-3,cold-chain-break,3,Move Product to Backup,Transfer affected pallets to backup cold storage if available,false,30
runbook:coldchain-4,coldchain-4,cold-chain-break,4,Document Temperature Log,Export temperature logger data for QA incident report,true,5
runbook:coldchain-5,coldchain-5,cold-chain-break,5,Notify Quality Team,Alert QA manager via Teams and email with temperature exceedance details,true,1


