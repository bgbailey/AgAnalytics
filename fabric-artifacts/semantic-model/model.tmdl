/// ---------- fact_anomaly_events ----------

table fact_anomaly_events
	lineageTag: lt-tbl-fact-anomaly

	/// --- Measures: Anomaly & Risk ---

	measure 'Prevented Loss (USD)' = SUM(fact_anomaly_events[prevented_loss_usd])
		formatString: \$#,##0.00
		lineageTag: lt-m-prevented-loss

	measure 'Avg Response Time (min)' = AVERAGE(fact_anomaly_events[response_time_minutes])
		formatString: #,##0.0
		lineageTag: lt-m-response-time

	measure 'Anomaly Count' = COUNTROWS(fact_anomaly_events)
		formatString: #,##0
		lineageTag: lt-m-anomaly-count

	measure 'Days Since Last Anomaly' =
		DATEDIFF(
			MAXX(fact_anomaly_events, fact_anomaly_events[start_time]),
			TODAY(),
			DAY
		)
		formatString: #,##0
		lineageTag: lt-m-days-since-anomaly

	/// --- Columns ---

	column event_id
		dataType: string
		lineageTag: lt-col-anom-id
		summarizeBy: none
		sourceColumn: event_id

	column start_time
		dataType: dateTime
		formatString: General Date
		lineageTag: lt-col-anom-start
		summarizeBy: none
		sourceColumn: start_time

	column end_time
		dataType: dateTime
		formatString: General Date
		lineageTag: lt-col-anom-end
		summarizeBy: none
		sourceColumn: end_time

	column greenhouse_id
		dataType: string
		lineageTag: lt-col-anom-gh
		summarizeBy: none
		sourceColumn: greenhouse_id
		isHidden

	column zone_ids
		dataType: string
		lineageTag: lt-col-anom-zones
		summarizeBy: none
		sourceColumn: zone_ids

	column anomaly_type
		dataType: string
		lineageTag: lt-col-anom-type
		summarizeBy: none
		sourceColumn: anomaly_type

	column severity
		dataType: string
		lineageTag: lt-col-anom-severity
		summarizeBy: none
		sourceColumn: severity

	column root_cause
		dataType: string
		lineageTag: lt-col-anom-cause
		summarizeBy: none
		sourceColumn: root_cause

	column estimated_loss_usd
		dataType: double
		formatString: \$#,##0.00
		lineageTag: lt-col-anom-est-loss
		summarizeBy: sum
		sourceColumn: estimated_loss_usd

	column prevented_loss_usd
		dataType: double
		formatString: \$#,##0.00
		lineageTag: lt-col-anom-prev-loss
		summarizeBy: sum
		sourceColumn: prevented_loss_usd

	column response_time_minutes
		dataType: double
		formatString: #,##0.0
		lineageTag: lt-col-anom-resp
		summarizeBy: average
		sourceColumn: response_time_minutes

	column resolution_status
		dataType: string
		lineageTag: lt-col-anom-status
		summarizeBy: none
		sourceColumn: resolution_status

	partition fact_anomaly_events = entity
		mode: directLake
		source
			entityName: fact_anomaly_events
			schemaName: dbo
			expressionSource: DatabaseQuery


/// ============================================================
///  DIMENSION TABLES
/// ============================================================

/// ---------- dim_date ----------

table dim_date
	lineageTag: lt-tbl-dim-date
	dataCategory: Time

	column date_key
		dataType: dateTime
		formatString: Short Date
		lineageTag: lt-col-date-key
		summarizeBy: none
		sourceColumn: date_key
		isKey

	column date
		dataType: dateTime
		formatString: Short Date
		lineageTag: lt-col-date-date
		summarizeBy: none
		sourceColumn: date

	column day_name
		dataType: string
		lineageTag: lt-col-date-dayname
		summarizeBy: none
		sourceColumn: day_name

	column day_of_week
		dataType: int64
		formatString: 0
		lineageTag: lt-col-date-dow
		summarizeBy: none
		sourceColumn: day_of_week

	column week_num
		dataType: int64
		formatString: 0
		lineageTag: lt-col-date-week
		summarizeBy: none
		sourceColumn: week_num

	column month_name
		dataType: string
		lineageTag: lt-col-date-monthname
		summarizeBy: none
		sourceColumn: month_name

	column month_num
		dataType: int64
		formatString: 0
		lineageTag: lt-col-date-monthnum
		summarizeBy: none
		sourceColumn: month_num
		sortByColumn: month_num

	column quarter
		dataType: string
		lineageTag: lt-col-date-quarter
		summarizeBy: none
		sourceColumn: quarter

	column year
		dataType: int64
		formatString: 0
		lineageTag: lt-col-date-year
		summarizeBy: none
		sourceColumn: year

	column fiscal_year
		dataType: int64
		formatString: 0
		lineageTag: lt-col-date-fy
		summarizeBy: none
		sourceColumn: fiscal_year

	column is_weekend
		dataType: boolean
		lineageTag: lt-col-date-weekend
		summarizeBy: none
		sourceColumn: is_weekend

	column season
		dataType: string
		lineageTag: lt-col-date-season
		summarizeBy: none
		sourceColumn: season

	column day_of_year
		dataType: int64
		formatString: 0
		lineageTag: lt-col-date-doy
		summarizeBy: none
		sourceColumn: day_of_year

	/// Date Hierarchy: Year > Quarter > Month > Date
	hierarchy 'Date Hierarchy'
		lineageTag: lt-hier-date

		level Year
			lineageTag: lt-hier-date-year
			column: year

		level Quarter
			lineageTag: lt-hier-date-quarter
			column: quarter

		level Month
			lineageTag: lt-hier-date-month
			column: month_name

		level Date
			lineageTag: lt-hier-date-day
			column: date

	partition dim_date = entity
		mode: directLake
		source
			entityName: dim_date
			schemaName: dbo
			expressionSource: DatabaseQuery


/// ---------- dim_greenhouse ----------

table dim_greenhouse
	lineageTag: lt-tbl-dim-greenhouse

	column greenhouse_id
		dataType: string
		lineageTag: lt-col-gh-id
		summarizeBy: none
		sourceColumn: greenhouse_id
		isKey

	column name
		dataType: string
		lineageTag: lt-col-gh-name
		summarizeBy: none
		sourceColumn: name

	column location_city
		dataType: string
		lineageTag: lt-col-gh-city
		summarizeBy: none
		sourceColumn: location_city

	column location_state
		dataType: string
		lineageTag: lt-col-gh-state
		summarizeBy: none
		sourceColumn: location_state

	column country
		dataType: string
		lineageTag: lt-col-gh-country
		summarizeBy: none
		sourceColumn: country

	column latitude
		dataType: double
		formatString: #,##0.000000
		lineageTag: lt-col-gh-lat
		summarizeBy: none
		sourceColumn: latitude

	column longitude
		dataType: double
		formatString: #,##0.000000
		lineageTag: lt-col-gh-lon
		summarizeBy: none
		sourceColumn: longitude

	column size_sqft
		dataType: int64
		formatString: #,##0
		lineageTag: lt-col-gh-size
		summarizeBy: sum
		sourceColumn: size_sqft

	column zone_count
		dataType: int64
		formatString: #,##0
		lineageTag: lt-col-gh-zones
		summarizeBy: sum
		sourceColumn: zone_count

	column growing_method
		dataType: string
		lineageTag: lt-col-gh-method
		summarizeBy: none
		sourceColumn: growing_method

	/// Geography Hierarchy: Country > State > City
	hierarchy Geography
		lineageTag: lt-hier-geo

		level Country
			lineageTag: lt-hier-geo-country
			column: country

		level State
			lineageTag: lt-hier-geo-state
			column: location_state

		level City
			lineageTag: lt-hier-geo-city
			column: location_city

	partition dim_greenhouse = entity
		mode: directLake
		source
			entityName: dim_greenhouse
			schemaName: dbo
			expressionSource: DatabaseQuery


